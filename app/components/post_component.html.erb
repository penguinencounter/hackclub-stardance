<% if git_commit? %>
  <article class="post post--git_commit">
    <%= render "shared/inspector", record: postable %>
    <div class="post__git-commit-message">
      <%= link_to postable.title, postable.url, target: "_blank", rel: "noopener" %>
    </div>
    <div class="post__git-commit-details">
      <div class="post__git-commit-time"><%= posted_at_text %> ago</div>
      <code class="post__git-commit-sha">(<%= postable.short_sha %>)</code>
    </div>
    <% if postable.stats_summary.present? %>
      <span class="post__git-commit-stats"><%= postable.stats_summary %></span>
    <% end %>
  </article>
<% else %>
  <article class="<%= article_classes %>">
    <div class="post__content">
      <% if deleted? %>
        <div class="post__deleted-banner">
          <strong>DELETED DEVLOG</strong>
          <span>Deleted on <%= postable.deleted_at.strftime("%B %d, %Y at %I:%M %p") %></span>
          <span class="post__deleted-banner-note">This content is only visible to admins/fraud review</span>
        </div>
      <% end %>
      <% if unapproved_ship_event? && helpers.current_user&.admin? %>
        <div class="post__admin-only-banner">
          <strong>⏳ PENDING APPROVAL</strong>
          <span>Status: <%= postable.certification_status.titleize %></span>
          <span class="post__admin-only-banner-note">This ship event is only visible to admins</span>
        </div>
      <% end %>
      <header class="post__header">
        <div class="post__avatar">
          <%= image_tag post.user&.avatar || "https://ca.slack-edge.com/T0266FRGM-U07GZPGJX1G-g98be5e77f20-512", alt: author_name, class: "post__avatar" %>
        </div>
        <div class="post__meta">
          <div class="post__author">

            <% if post.user.present? %>
              <%= link_to author_name, user_path(post.user) %><%= " ⚡" if post.user&.admin? %>
            <% else %>
              <%= author_name %><%= " ⚡" if post.user&.admin? %>
            <% end %>
            <% if (helpers.current_user&.admin? || helpers.current_user&.fraud_dept?) && post.user %>
              <span class="post__admin-tools">
                <%= link_to "🔨", helpers.admin_user_path(post.user), title: "Admin profile" %>
              </span>
            <% end %>
            <span class="post__author-activity"><%= author_activity %></span>
            <% if project_title.present? %>
              <%= link_to project_title, project_path(post.project) %>
            <% else %>
              <span>something</span>
            <% end %>
          </div>
          <div class="post__time"><%= posted_at_text %> ago</div>
          <% if duration_text.present? %>
            <div class="post__duration"><%= duration_text %> logged</div>
          <% end %>
        </div>
      </header>

      <%= render "shared/inspector", record: postable %>
      <%= render "shared/inspector", record: post.user if post.user %>

      <% if ship_event? %>
        <h2 class="post__ship-title">Shipped this project!</h2>
        <% if show_ship_event_payout_footer? %>
          <% if postable.payout.present? %>
            <div class="post__payout-footer">
              <div class="post__payout-item">
                <span class="post__payout-label">Hours:</span>
                <span class="post__payout-value"><%= postable.read_attribute(:hours)&.round(2) || '—' %></span>
              </div>
              <div class="post__payout-item">
                <span class="post__payout-label">Stardust:</span>
                <span class="post__payout-value">🍪 <%= postable.payout.to_i %></span>
              </div>
              <div class="post__payout-item">
                <span class="post__payout-label">Multiplier:</span>
                <span class="post__payout-value"><%= postable.multiplier&.round(2) || '—' %> stardust/hr</span>
              </div>
            </div>
          <% else %>
            <% estimate = estimated_payout_data %>
            <div class="post__payout-footer post__payout-footer--estimate">
              <div class="post__payout-item">
                <span class="post__payout-label">Hours:</span>
                <span class="post__payout-value"><%= estimate&.dig(:hours) || '—' %></span>
              </div>
              <div class="post__payout-item">
                <span class="post__payout-label">Stardust:</span>
                <span class="post__payout-value">🍪 ~<%= estimate&.dig(:cookies) || '—' %></span>
              </div>
              <div class="post__payout-item">
                <span class="post__payout-label">Multiplier:</span>
                <span class="post__payout-value"><%= estimate&.dig(:multiplier) || '—' %> stardust/hr</span>
              </div>
              <div class="post__payout-estimate-notice">
                <small>⏳ Estimated (payout not issued yet)</small>
              </div>
            </div>
          <% end %>
        <% end %>

        <% if show_votes_breakdown? %>
          <% votes = ship_event_payout_countable_votes %>
          <details class="post__votes-breakdown">
            <summary><%= votes.size %> vote<%= votes.size == 1 ? "" : "s" %> received</summary>
            <% votes.each_with_index do |vote, index| %>
              <div class="post__vote-entry">
                <p>
                  <strong>Voter #<%= votes.size - index %></strong>
                  &nbsp; <%= vote.time_taken_to_vote ? "#{vote.time_taken_to_vote}s" : "—" %>
                  <% opened = [ vote.demo_url_clicked? ? "Demo" : nil, vote.repo_url_clicked? ? "Repo" : nil ].compact %>
                  <%= "· Opened #{opened.join(", ")}" if opened.any? %>
                </p>
                <p><%= Vote::SCORE_COLUMNS_BY_CATEGORY.map { |cat, col| "#{cat.to_s.humanize} #{vote[col]}/9" }.join(" · ") %></p>
                <blockquote class="post__vote-reason"><%= vote.reason %></blockquote>
              </div>
            <% end %>
          </details>
        <% end %>
      <% end %>

      <% if fire_event? %>
        <h2 class="post__fire-title">Tagged your project as well cooked!</h2>
      <% end %>

      <% if postable.respond_to?(:body) && postable.body.present? %>
        <div class="post__body"><%= helpers.md postable.body %></div>
      <% end %>

      <% if attachments.any? %>
        <div class="post__attachments" data-controller="post-attachments">
          <div class="post__viewport">
            <button type="button" class="post__chevron post__chevron--prev" data-post-attachments-target="prevButton" data-action="post-attachments#prev" aria-label="Previous" hidden>
              <%= helpers.inline_svg_tag "icons/chevron-down.svg", class: "post__chevron-icon", focusable: "false", aria: { hidden: true } %>
            </button>
            <div class="post__track" data-post-attachments-target="track">
              <% attachments.each do |att| %>
                <div class="post__slide">
                  <% if att.image? %>
                    <%= image_tag(att.content_type == "image/gif" ? att : att.variant(:medium),
                          class: "post__attachment post__attachment--image post__image", alt: "Attachment", loading: "lazy") %>
                  <% elsif att.video? %>
                    <%= video_tag url_for(att), class: "post__attachment post__attachment--video", controls: true, preload: "none" %>
                  <% else %>
                    <%= link_to url_for(att), class: "post__attachment post__attachment--file", target: "_blank", rel: "noopener" do %>
                      <%= helpers.inline_svg_tag("icons/paper.svg") %>
                      <span><%= att.filename %></span>
                    <% end %>
                  <% end %>
                </div>
              <% end %>
            </div>
            <button type="button" class="post__chevron post__chevron--next" data-post-attachments-target="nextButton" data-action="post-attachments#next" aria-label="Next" hidden>
              <%= helpers.inline_svg_tag "icons/chevron-down.svg", class: "post__chevron-icon", focusable: "false", aria: { hidden: true } %>
            </button>
            <div class="post__indicators" data-post-attachments-target="indicators" hidden></div>
          </div>
        </div>
      <% end %>

      <% if show_interactions? %>
        <div class="post__interactions">
          <% if show_likes? %>
            <%= render "likes/button", likeable: postable %>
          <% end %>
          <% if show_comments? %>
            <div class="comments-count">
              <%= helpers.inline_svg_tag("icons/paper.svg") %>
              <span class="comments-count__count"><%= commentable.comments_count %></span>
            </div>
          <% end %>
          <% if show_actions? && can_edit? %>
            <div class="post__actions">
              <%= link_to edit_devlog_path, class: "post__action-btn", title: "Edit devlog" do %>
                <%= helpers.inline_svg_tag("icons/pencil.svg", class: "post__action-icon") %>
              <% end %>
              <%= button_to delete_devlog_path, method: :delete, class: "post__action-btn post__action-btn--danger", title: "Delete devlog", form: { onsubmit: "return confirm('Are you sure you want to delete this devlog? This action cannot be undone.')" } do %>
                <%= helpers.inline_svg_tag("icons/trash-bin.svg", class: "post__action-icon") %>
              <% end %>
            </div>
          <% elsif show_actions? && can_force_delete? %>
            <div class="post__actions">
              <%= button_to force_delete_devlog_path,
                method: :delete,
                class: "post__action-btn post__action-btn--danger",
                title: "Force delete devlog (Admin/Fraud)",
                form: { onsubmit: "return confirm('⚠️ ADMIN/FRAUD OVERRIDE ⚠️\\n\\nThis project is SHIPPED. You are about to override ship protection and force delete this devlog.\\n\\nThis action will be audit logged.\\n\\nAre you absolutely sure?')" } do %>
                <%= helpers.inline_svg_tag("icons/trash-bin.svg", class: "post__action-icon") %>
              <% end %>
            </div>
          <% end %>
        </div>
        <% if show_comments? %>
          <%= render "comments/section", commentable: postable %>
        <% end %>
      <% end %>
    </div>
  </article>
<% end %>
