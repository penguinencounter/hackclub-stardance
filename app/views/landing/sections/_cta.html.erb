<section class="cta-section">
  <h2 class="cta-section__title">Make this summer <span class="cta-section__title--italic">count.</span></h2>

  <p class="cta-section__subtitle">What else are you gonna do?<br>Sign up and build something you&rsquo;re actually proud of.</p>

  <div class="cta-section__form">
    <div class="rsvp-form">
      <%= form_with url: rsvps_path, scope: :rsvp, method: :post, local: true do |form| %>
        <div class="rsvp-form__row">
          <div class="input-red">
            <div>
              <%= form.email_field :email, placeholder: "Enter your email...", autocomplete: "off", required: true %>
            </div>
          </div>

          <%= form.button type: "submit", class: "btn btn--red btn--striped" do %>
            <div>RSVP &rarr;</div>
          <% end %>

          <%= image_tag "landing/cta/star-creature.png", class: "rsvp-form__star", alt: "" %>
        </div>
      <% end %>
      <p class="cta-section__caption">For all teens aged 13&ndash;18.</p>
    </div>
  </div>
</section>
