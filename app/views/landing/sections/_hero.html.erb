<div class="section hero" role="main" data-controller="parallax">
  <%= image_tag image_url("landing/hero/earth.png"), class: "hero__earth", alt: "", data: { parallax_target: "layer", speed: "0.5" } %>
  <%= image_tag image_url("landing/hero/moon.png"), class: "hero__moon", alt: "", data: { parallax_target: "layer", speed: "0.35" } %>

  <div class="rsvp-container">
    <p class="hero__eyebrow">By <%= link_to "Hack Club", "https://hackclub.com", target: "_blank", rel: "noopener" %>. For teens (13–18).</p>
    <h1 class="hero__headline"><span>Calling all coders,</span><span>builders, and <span class="hero__headline--italic">makers</span></span></h1>
    <p class="hero__subhead">The largest STEM challenge of the summer: make anything you want and win free prizes.</p>

    <div class="rsvp-form">
      <%= form_with url: rsvps_path, scope: :rsvp, method: :post, local: true do |form| %>
        <div class="rsvp-form__row">
          <%= image_tag image_url("landing/hero/doodle-arrow.png"), class: "hero__doodle-arrow", alt: "" %>
          <div class="input-red">
            <div>
              <%= form.email_field :email, placeholder: "Enter your email...", autocomplete: "off", required: true %>
            </div>
          </div>

          <%= form.button type: "submit", class: "btn btn--red btn--striped" do %>
            <div>RSVP &rarr;</div>
          <% end %>
        </div>
      <% end %>
      <p class="hero__caption">For all teens aged 13–18.</p>
    </div>
  </div>

  <div class="hero__nasa-photo" data-parallax-target="layer" data-speed="0.2">
    <%= image_tag image_url("landing/hero/nasa-hero.png"), loading: "eager", fetchpriority: "high", alt: "NASA Orion spacecraft", class: "hero__nasa-photo-img" %>
  </div>
</div>
