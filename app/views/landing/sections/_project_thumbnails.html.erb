<div class="project-thumbs-section">
  <div class="project-thumbs-section__curve" aria-hidden="true" data-controller="curve-draw">
    <svg class="project-thumbs-section__curve-svg" preserveAspectRatio="none" viewBox="0 0 564 590" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path data-curve-draw-target="path" d="M564 3.09808C496.041 3.09831 246.69 -17.2283 141.753 68.6377C36.8162 154.504 -31.8602 264.732 17.1197 407.622C69.1558 559.427 235.854 589 299.816 589" stroke="white" stroke-width="2" />
    </svg>
  </div>

  <div class="project-thumbs-section__step">
    <h3 class="project-thumbs-section__step-heading">1. Make projects</h3>
    <p class="project-thumbs-section__step-lead">Build any website, game, app, hardware of your liking. No experience required.</p>
  </div>

  <div class="project-thumbs" aria-label="Past projects by teens" data-controller="project-thumbs-loop">
   <div class="project-thumbs__track" data-project-thumbs-loop-target="track">
    <% items = [
      { url: "https://shaaarkai.itch.io/specter", mod: 1, by: "By Yessa, 18", img: "landing/projects/yessa.png", alt: "Project by Yessa", desc: "A knight bravely attempts to escape a haunted cave while pursued by his own ghost." },
      { url: "https://github.com/Dieu-de-l-elec/AngstromIO-devboard", mod: 2, by: "By Clément, 17", img: "landing/projects/clement.png", alt: "Project by Clément", desc: "A pocket‑sized, custom Attiny1616 devboard, with two GPIOs and I2C, a dual‑CH340 UPDI programmer!" },
      { url: "https://github.com/geg-tech/brew-keeb", mod: 3, by: "By Alexander, 16", img: "landing/projects/alexander.png", alt: "Project by Alexander", desc: "A fully documented, custom keyboard with built-in RGB, OLED and a USB hub made for Blueprint!" },
      { url: "https://deltea.itch.io/starbird", mod: 4, by: "By Deltea, 16", img: "landing/projects/deltea.png", alt: "Project by Deltea", desc: "A platformer game about a bird collecting stars, made for Milkyway!" },
      { url: "https://github.com/SteveMan67/platformed", mod: 5, by: "By Steve, 16", img: "landing/projects/steve.avif", alt: "Project by Steve", desc: "A platformer with a fully functioning level editor, online level sharing, and trigger system, built from the ground up in Javascript for Flavortown." }
    ] %>
    <%# Items are rendered twice on mobile so the auto-scroll loop is seamless;
        on desktop the second copy is hidden via CSS (display: none). %>
    <% (1..2).each do |pass| %>
      <% items.each do |item| %>
        <%= link_to item[:url], class: "project-thumbs__item project-thumbs__item--#{item[:mod]}#{' project-thumbs__item--clone' if pass == 2}", target: "_blank", rel: "noopener noreferrer", "aria-hidden": (pass == 2 ? "true" : nil), tabindex: (pass == 2 ? -1 : nil) do %>
          <div class="project-thumbs__tab"><%= item[:by] %></div>
          <div class="project-thumbs__img-wrap">
            <%= image_tag image_url(item[:img]), class: "project-thumbs__img", alt: item[:alt], loading: "lazy" %>
          </div>
          <div class="project-thumbs__desc" aria-hidden="true"><%= item[:desc] %></div>
        <% end %>
      <% end %>
    <% end %>
   </div>
  </div>

  <div class="project-thumbs-section__new-to-coding">
    <p class="project-thumbs-section__ntc-title">New to coding?</p>
    <p class="project-thumbs-section__ntc-body">Don't worry &mdash; we have guides for complete beginners!</p>
  </div>
</div>
