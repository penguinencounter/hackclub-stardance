<% content_for :title, @project.title %>
<% content_for :og_title, @project.title %>
<% content_for :og_description, truncate(@project.display_description.to_s, length: 200) %>
<% content_for :og_image, project_og_image_url(@project, format: :png) %>
<% content_for :twitter_card, "summary_large_image" %>
<% content_for :og_author, @project.memberships.find_by(role: :owner)&.user&.display_name %>

<% owner = @project.memberships.find_by(role: :owner)&.user %>
<% if owner&.search_engine_indexing_off? %>
  <% content_for :head do %>
    <meta name="robots" content="noindex, nofollow">
  <% end %>
<% end %>

<div class="projects-show">
  <div class="projects-show__container" style="position: relative;">
    <%= render "shared/debug_info", record: @project %>
    <%= render "shared/admin_state_machine", record: @project %>
    <%= render ProjectShowCardComponent.new(project: @project, current_user: current_user) %>

    <% if @show_ai_coding_time_ignored_card %>
      <div id="ai-coding-time-ignored-card" class="projects-show__info-card">
        <h2>Note: AI coding time is being ignored</h2>
        <h3>Time spent coding entirely using AI agents like GitHub Copilot is being automatically filtered out of total project time. If you were using AI agents excessively and see discrepancies in your coding time, this is likely why. Please ask the support team in <a href="https://hackclub.slack.com/app_redirect?channel=C09MATKQM8C" rel="noopener" target="_blank">#flavortown-help</a> if you have any questions!</h3>
        <button id="dismiss-ai-coding-time-ignored" class="projects-show__info-card-dismiss-button" aria-label="Dismiss" data-dismiss-url="<%= dismiss_thing_path %>" onclick="fetch(this.dataset.dismissUrl, {method: 'POST', headers: {'X-CSRF-Token': document.querySelector('meta[name=csrf-token]').content, 'Content-Type': 'application/x-www-form-urlencoded'}, body: 'thing_name=ai_coding_time_ignored_card'}); this.closest('.projects-show__info-card').remove();">X</button>
      </div>
    <% end %>

    <% if current_user.present? %>
      <div class="mt-4" style="display: flex; gap: var(--space-m); align-items: center;">
        <% if current_user.admin? || current_user.fraud_dept? %>
          <%= link_to admin_project_path(@project), style: "background: #ff9500; color: white; border: 1px solid #cc7700; padding: 6px 12px; border-radius: 4px; text-decoration: none; font-size: 14px; display: flex; align-items: center; gap: 0.25rem;" do %>
            🔨 Admin
          <% end %>
          <%= render "shared/admin_copy_debug", record: @project, record_type: "Project", url: project_url(@project, host: "flavortown.hackclub.com", protocol: "https") %>
        <% end %>
        <% if @project.users.include?(current_user) %>
          <%= render ButtonComponent.new(
                text: "Add Devlog",
                color: :brown,
                href: new_project_devlog_path(@project)
              ) %>
        <% end %>

        <% if policy(:helper).access? %>
          <% helper_user = owner || @project.users.first %>
          <% if helper_user.present? %>
            <%= link_to "View user on helper dash", helper_user_path(helper_user), class: "btn btn--brown" %>
          <% end %>
          <%= link_to "View project on helper dash", helper_project_path(@project), class: "btn btn--brown" %>
        <% end %>

      </div>
    <% end %>

    <% if @votes_for_payout.present? %>
      <section class="projects-show__payout-votes" aria-label="Votes needed to unlock payout">
        <h3 class="projects-show__payout-votes-title">Votes needed to unlock payout <span id="votes-progress-info">ⓘ</span></h3>

        <div class="projects-show__payout-votes-row">
          <progress
            class="projects-show__payout-votes-progress"
            value="<%= @votes_for_payout[:current] %>"
            max="<%= @votes_for_payout[:required] %>">
          </progress>

          <div class="projects-show__payout-votes-text">
            <strong><%= @votes_for_payout[:current] %></strong> / <%= @votes_for_payout[:required] %>
            <% if @votes_for_payout[:remaining] > 0 %>
              (<%= @votes_for_payout[:remaining] %> left)
            <% else %>
              (ready!)
            <% end %>
          </div>
        </div>
      </section>
    <% end %>

    <% if @posts.present? %>
      <div class="projects-show__timeline">
        <div class="mt-4" style="display: grid; gap: var(--space-xl);">
          <% @posts.each do |post| %>
            <%= render PostComponent.new(
                  post: post,
                  current_user: current_user,
                  lapse_badge: @devlog_lapse_badges[post.postable_id]
                ) %>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if current_user.present? && (!@project.users.include?(current_user) || Rails.env.development?) %>
      <%= render layout: "shared/modal", locals: { id: "project-report-modal", title: "Report project?" } do %>
        <h2>We want good, high quality projects in Stardance. If you believe this project violates our community guidelines, please let us know why:</h2>

        <%= form_with model: Project::Report.new, url: project_reports_path(@project), local: true do |f| %>
          <div class="form-field">
            <div class="form-checkbox">
              <%= f.radio_button :reason, "low_effort", id: "project_report_reason_low_effort", required: true %>
              <%= f.label :reason, "Low-effort project", for: "project_report_reason_low_effort" %>
            </div>

            <div class="form-checkbox">
              <%= f.radio_button :reason, "undeclared_ai", id: "project_report_reason_undeclared_ai" %>
              <%= f.label :reason, "Uses AI but it's undeclared", for: "project_report_reason_undeclared_ai" %>
            </div>

            <div class="form-checkbox">
              <%= f.radio_button :reason, "demo_broken", id: "project_report_reason_demo_broken" %>
              <%= f.label :reason, "Demo does not work", for: "project_report_reason_demo_broken" %>
            </div>

            <div class="form-checkbox">
              <%= f.radio_button :reason, "other", id: "project_report_reason_other" %>
              <%= f.label :reason, "Other", for: "project_report_reason_other" %>
            </div>
          </div>

          <div class="form-group">
            <%= f.text_area :details,
                  rows: 4,
                  minlength: 20,
                  required: true,
                  class: "form-field",
                  placeholder: "Share a short explanation (20+ characters)." %>
            <small>Why are you reporting this project? (20+ characters)</small>
          </div>

          <div class="modal__actions">
            <%= f.submit "Submit", class: "modal__actions-close" %>
            <button type="button" class="modal__actions-close" onclick="document.getElementById('project-report-modal').close()">Cancel</button>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>

<%= render TooltipComponent.new(target_id: "votes-progress-info", position: :top) do %>
  <strong>Votes needed to unlock payout</strong>
  This shows the number of times <i>other</i> people need to vote for your project!
<% end %>
